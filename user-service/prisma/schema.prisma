generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role{
    USER
    ADMIN
}

model User {
    id String @id @default(cuid())
    email String @unique
    password String
    firstName String?
    lastName String?
    phone String?
    address String?
    imageUrl String?
    role Role
    isActive Boolean @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model PasswordResetOtp {
    id        String   @id @default(cuid())
    email     String
    otp       String
    expiresAt DateTime
    createdAt  DateTime @default(now())
}